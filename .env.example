# ---------------------------------------------------------------------------
# Green Candle Therapy — environment template
# Copy to `.env.local` and fill in. Real values are never committed (.env* is
# gitignored; only this template is tracked). Secrets stay server-side.
# ---------------------------------------------------------------------------

# --- Data layer (SERVER-SIDE ONLY — never rename to NEXT_PUBLIC_*) ---
# CoinGecko free "Demo" API key. Used only inside the Next.js API route that
# proxies /search and /ohlc. Keeping it server-side is a hard requirement.
COINGECKO_API_KEY=

# --- Monad reads (server-side) ---
# RPC endpoint the API route uses to read totalRecoveries() from mainnet.
# e.g. https://rpc.monad.xyz
MONAD_RPC_URL=

# --- Public chain config (safe to expose to the browser) ---
# Deployed RecoveryLog contract address on Monad mainnet.
NEXT_PUBLIC_CONTRACT_ADDRESS=
# Monad mainnet chain id (decimal). e.g. 143
NEXT_PUBLIC_MONAD_CHAIN_ID=
# WalletConnect Cloud project id — used by RainbowKit/wagmi for the wallet
# connector. Public by design (safe in the browser). Get one at cloud.walletconnect.com.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ---------------------------------------------------------------------------
# Contract deployment (Foundry, ./contracts) — used locally only.
# Prefer a Foundry keystore (`cast wallet import`) over a raw private key.
# See contracts/README.md. If a raw key is used it lives here in .env only and
# is never printed or handled by app tooling.
# ---------------------------------------------------------------------------
DEPLOYER_PRIVATE_KEY=
# Optional: Monadscan API key for etherscan-style verification.
# Not required — the default verification path is Sourcify.
MONADSCAN_API_KEY=
